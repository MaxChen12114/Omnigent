{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmnigentP",
  "version": "4.69.0",
  "identifier": "com.omnigent.app",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OmnigentP",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "Boundless AI multi-branch creation platform",
    "longDescription": "Omnigent is a boundless AI multi-branch creation platform for roleplay, writing, coding, node flows, images and voice."
  }
}
